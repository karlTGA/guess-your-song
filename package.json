{
    "name": "guess-your-song",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "yarn workspaces foreach -Api --exclude guess-your-song --jobs unlimited run dev",
        "build": "yarn workspaces foreach -Apt run build",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "yarn workspaces foreach -Apt run typecheck",
        "lint": "biome check .",
        "lint:fix": "biome check --fix ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.10",
        "typescript": "^5.7.0",
        "vitest": "^3.1.0"
    },
    "packageManager": "yarn@4.6.0",
    "engines": {
        "node": ">=20"
    }
}