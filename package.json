{
    "name": "guess-your-song",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "dev": "yarn workspaces foreach -Ap --jobs unlimited run dev",
        "build": "yarn workspaces foreach -Apt run build",
        "test": "vitest run --no-file-parallelism",
        "test:watch": "vitest --no-file-parallelism"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^3.1.0"
    },
    "packageManager": "yarn@4.6.0",
    "engines": {
        "node": ">=20"
    }
}